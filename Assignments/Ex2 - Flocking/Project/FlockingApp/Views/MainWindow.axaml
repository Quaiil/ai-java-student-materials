<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:Uwu.Simulation.Steering.Flocking.Views"
        x:Class="Uwu.Simulation.Steering.Flocking.Views.MainWindow"
        Title="Flocking" Width="1264" Height="600">
  <Grid ColumnDefinitions="3*,*">
    <!-- Render area -->
    <views:RenderView x:Name="RenderHost" Grid.Column="0" PointerPressed="RenderHost_PointerPressed" />

    <!-- Control panel -->
    <ScrollViewer Grid.Column="1" Padding="10">
      <StackPanel Spacing="10">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Button x:Name="btnAddFlock" Content="Add Flock" Click="btnAddFlock_Click"/>
          <Button x:Name="btnRemoveFlock" Content="Remove Flock" Click="btnRemoveFlock_Click"/>
        </StackPanel>

        <ListBox x:Name="listFlocks" ItemsSource="{Binding Flocks}"
                 SelectionChanged="listFlocks_SelectionChanged" Height="180"/>

        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBlock Text="Boids:" VerticalAlignment="Center"/>
          <NumericUpDown x:Name="boidCount" Minimum="2" Maximum="100" Value="20"
                         ValueChanged="boidCount_ValueChanged" Width="150"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBlock Text="Flock Radius:" VerticalAlignment="Center"/>
          <NumericUpDown x:Name="flockRadius" Minimum="0" Maximum="1000" Value="100"
                         ValueChanged="flockRadius_ValueChanged" Width="150"/>
        </StackPanel>

        <HeaderedContentControl Header="Strength Weights">
          <Border Padding="8" Margin="4"
                  BorderBrush="#808080" BorderThickness="1" CornerRadius="6">
            <StackPanel Spacing="8">
              <StackPanel>
                <TextBlock Text="Alignment"/>
                <Slider x:Name="sliderAlignment" Minimum="0" Maximum="5"
                        ValueChanged="sliderAlignment_ValueChanged"/>
              </StackPanel>
              <StackPanel>
                <TextBlock Text="Cohesion"/>
                <Slider x:Name="sliderCohesion" Minimum="0" Maximum="5"
                        ValueChanged="sliderCohesion_ValueChanged"/>
              </StackPanel>
              <StackPanel>
                <TextBlock Text="Separation"/>
                <Slider x:Name="sliderSeparation" Minimum="0" Maximum="5"
                        ValueChanged="sliderSeparation_ValueChanged"/>
              </StackPanel>
            </StackPanel>
          </Border>
        </HeaderedContentControl>

        <StackPanel Orientation="Horizontal" Spacing="12">
          <RadioButton x:Name="radioStudent" Content="Student" Checked="radioStudent_Checked"/>
          <RadioButton x:Name="radioExample" Content="Example" IsChecked="True" Checked="radioExample_Checked"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBlock Text="Color:" VerticalAlignment="Center"/>
          <Button x:Name="btnColor" Content="Pick…" Click="btnColor_Click"/>
        </StackPanel>

        <TextBlock x:Name="labelFps" Text="FPS: 0000" FontWeight="Bold"/>
        <TextBlock x:Name="labelTotalBoids" Text="Total Boids: 00000"/>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
