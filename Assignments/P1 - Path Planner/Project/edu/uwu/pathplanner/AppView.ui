 <layoutdefault spacing="6" margin="11"/>
 <resources>
  <include location="AppView.qrc"/>
 </resources>
 <connections>
  <connection>
   <sender>actionExit</sender>
   <signal>triggered()</signal>
   <receiver>AppView</receiver>
   <slot>close()</slot>
   <hints>
    <hint type="sourcelabel">
     <x>-1</x>
     <y>-1</y>
    </hint>
    <hint type="destinationlabel">
     <x>270</x>
     <y>215</y>
    </hint>
   </hints>
  </connection>
 </connections>
